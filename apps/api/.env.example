# Entertainment Business Exchange — Environment Configuration
# Copy to .env and fill in values for your deployment

# ── Core ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development                    # production | development | test
JWT_SECRET=                             # REQUIRED: >= 32 chars for HS256

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/entertainment_exchange
# Leave blank for in-memory-only operation (dev/test)

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# REQUIRED in production — comma-separated allowed origins
# Leave blank in production to deny cross-origin requests

# ── AI / LLM ────────────────────────────────────────────────────────────────
ANTHROPIC_AUTH_TOKEN=                   # For agent executor (Claude API)
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_API_KEY=                         # For embeddings (text-embedding-3-small)
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_PROVIDER=openai              # openai | cohere | local (defaults to hash fallback)

# ── Payments & Billing ──────────────────────────────────────────────────────
PAYMENT_LINK_BASE_URL=https://pay.example.com

# ── OAuth / SSO ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# ── Security ────────────────────────────────────────────────────────────────
TRUST_PROXY=false                       # Set true if behind a trusted reverse proxy
ALLOW_TEST_HEADERS=false                # Set true only in test environments

# ── Notifications ────────────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SLACK_WEBHOOK_URL=                    # Default Slack webhook (can be overridden per tenant)

# ── Sandbox ──────────────────────────────────────────────────────────────────
# SANDBOX_ENABLED=false                 # Global sandbox mode override

# ── API ──────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3000
