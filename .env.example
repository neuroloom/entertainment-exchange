# Entertainment Business Exchange -- Environment Variables

# -- Required -----------------------------------------------------------------------
# Secret key for HS256 JWT signing. Minimum 32 characters.
# Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# PostgreSQL connection string. When set, stores persist to PG and hydrate from PG
# on startup. Without it, the API runs with in-memory stores only.
DATABASE_URL=postgres://entx:entx_secret@localhost:5432/entertainment_exchange

# -- Optional -----------------------------------------------------------------------
# HTTP server port
PORT=3000

# Runtime environment: development | production | test
# - development: verbose logging, header-based auth disabled
# - production:  strict CORS, JWT-only auth
# - test:        header-based auth enabled (x-actor-permissions)
NODE_ENV=development

# Comma-separated list of allowed CORS origins.
# Required in production. Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000

# Pino log level: trace | debug | info | warn | error | fatal
# Fastify/Pino reads this natively.
LOG_LEVEL=info

# Set to "true" when behind a reverse proxy (nginx, load balancer).
# Enables trust of X-Forwarded-For for rate limiting.
TRUST_PROXY=false

# -- AI / Embeddings ---------------------------------------------------------------
# OpenAI API key for embedding generation (powers semantic cache).
# Required for L2 semantic cache. Without it, embeddings fall back to FNV hash.
OPENAI_API_KEY=

# Embedding provider backend. Defaults to "openai".
EMBEDDING_PROVIDER=openai

# OpenAI-compatible API base URL. Defaults to https://api.openai.com/v1.
# Set to override for proxies or OpenAI-compatible backends.
OPENAI_BASE_URL=

# -- Agent Inference (Anthropic) ---------------------------------------------------
# Anthropic API key for AI agent inference (booking, marketplace, negotiation agents).
# Without this, agent run endpoints will fail with authentication errors.
ANTHROPIC_AUTH_TOKEN=

# Anthropic API base URL. Defaults to https://api.anthropic.com.
# Set to override for proxies or Vertex AI / AWS Bedrock gateways.
ANTHROPIC_BASE_URL=
